generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  DONOR
  ORPHANAGE_ADMIN
  SUPER_ADMIN
}

enum OrphanageStatus {
  PENDING
  VERIFIED
  SUSPENDED
}

enum DonationStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  FEDAPAY
  MTN
  BANK_TRANSFER
}

enum SubscriptionFrequency {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAUSED
}

enum NotificationChannel {
  EMAIL
  PUSH
  SMS
}

enum NeedCategory {
  FOOD
  CLOTHING
  EDUCATION
  MEDICAL
  SHELTER
  OTHER
}

enum NeedStatus {
  OPEN
  PARTIALLY_FUNDED
  FUNDED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  passwordHash    String?
  avatarUrl       String?
  phone           String?
  locale          String   @default("fr")
  currency        String   @default("XOF")
  isAnonymousDonor Boolean  @default(false)
  isVerified      Boolean  @default(false)
  role            Role     @default(DONOR)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  authProviders   AuthProvider[]
  donations       Donation[]
  subscriptions   Subscription[]
  sponsorships    Sponsorship[]
  notifications   Notification[]
  taxReceipts     TaxReceipt[]
  reviews         Review[]
  testimonials    Testimonial[]
  engagements     Engagement[]
  payments        Payment[]
  managedOrphanages Orphanage[] @relation("OrphanageAdmin")
}

// Stocke les connexions OAuth (Google, Apple) séparément du compte principal
model AuthProvider {
  id           String   @id @default(cuid())
  provider     String   // "google" | "apple"
  providerId   String   // ID unique chez le fournisseur OAuth
  userId       String
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
}

model Orphanage {
  id                  String          @id @default(cuid())
  adminUserId         String
  name                String
  slug                String          @unique
  description         String          @db.Text
  country             String
  city                String
  address             String?
  lat                 Float?
  lng                 Float?
  childrenCount       Int
  phone               String?
  email               String?
  websiteUrl          String?
  coverImageUrl       String?
  status              OrphanageStatus @default(PENDING)
  certificationDocUrl String?
  verifiedAt          DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  admin               User            @relation("OrphanageAdmin", fields: [adminUserId], references: [id])
  needs               Need[]
  campaigns           Campaign[]
  sponsorships        Sponsorship[]
  events              Event[]
  reviews             Review[]
  testimonials        Testimonial[]
  donations           Donation[]
}

// Besoins spécifiques d'un orphelinat (nourriture, vêtements, etc.)
model Need {
  id          String       @id @default(cuid())
  orphanageId String
  title       String
  description String?      @db.Text
  category    NeedCategory
  targetAmount Decimal?    @db.Decimal(12, 2)
  raisedAmount Decimal     @default(0) @db.Decimal(12, 2)
  currency    String       @default("XOF")
  imageUrl    String?
  status      NeedStatus   @default(OPEN)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  orphanage   Orphanage    @relation(fields: [orphanageId], references: [id])
  donations   Donation[]
}

model Campaign {
  id           String         @id @default(cuid())
  orphanageId  String
  title        String
  description  String         @db.Text
  coverImageUrl String?
  targetAmount Decimal        @db.Decimal(12, 2)
  raisedAmount Decimal        @default(0) @db.Decimal(12, 2)
  currency     String         @default("XOF")
  status       CampaignStatus @default(DRAFT)
  startsAt     DateTime
  endsAt       DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  orphanage    Orphanage      @relation(fields: [orphanageId], references: [id])
  donations    Donation[]
}

// Enfant parrainé — données séparées de l'orphelinat pour la confidentialité
model Child {
  id          String        @id @default(cuid())
  orphanageId String
  firstName   String
  birthYear   Int
  gender      String?
  story       String?       @db.Text
  photoUrl    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  sponsorships Sponsorship[]
}

model Sponsorship {
  id          String   @id @default(cuid())
  sponsorId   String
  orphanageId String
  childId     String?
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("XOF")
  isActive    Boolean  @default(true)
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  createdAt   DateTime @default(now())

  sponsor     User        @relation(fields: [sponsorId], references: [id])
  orphanage   Orphanage   @relation(fields: [orphanageId], references: [id])
  child       Child?      @relation(fields: [childId], references: [id])
  letters     SponsorshipLetter[]
  subscription Subscription?
}

model SponsorshipLetter {
  id            String      @id @default(cuid())
  sponsorshipId String
  fromSponsor   Boolean     // true = du parrain vers l'enfant, false = de l'orphelinat
  content       String      @db.Text
  attachmentUrl String?
  createdAt     DateTime    @default(now())

  sponsorship   Sponsorship @relation(fields: [sponsorshipId], references: [id])
}

model Payment {
  id             String          @id @default(cuid())
  userId         String?
  provider       PaymentProvider
  providerPaymentId String       @unique // ID côté Stripe/PayPal/etc.
  amount         Decimal         @db.Decimal(12, 2)
  currency       String
  status         DonationStatus  @default(PENDING)
  metadata       Json?           // données brutes du webhook
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user           User?           @relation(fields: [userId], references: [id])
  donation       Donation?
  subscription   Subscription?
}

model Donation {
  id           String         @id @default(cuid())
  donorId      String?
  orphanageId  String
  needId       String?
  campaignId   String?
  paymentId    String         @unique
  amount       Decimal        @db.Decimal(12, 2)
  currency     String         @default("XOF")
  isAnonymous  Boolean        @default(false)
  note         String?
  status       DonationStatus @default(PENDING)
  createdAt    DateTime       @default(now())

  donor        User?      @relation(fields: [donorId], references: [id])
  orphanage    Orphanage  @relation(fields: [orphanageId], references: [id])
  need         Need?      @relation(fields: [needId], references: [id])
  campaign     Campaign?  @relation(fields: [campaignId], references: [id])
  payment      Payment    @relation(fields: [paymentId], references: [id])
  taxReceipt   TaxReceipt?
}

model Subscription {
  id            String                @id @default(cuid())
  userId        String
  sponsorshipId String?               @unique
  paymentId     String?               @unique
  amount        Decimal               @db.Decimal(12, 2)
  currency      String                @default("XOF")
  frequency     SubscriptionFrequency
  status        SubscriptionStatus    @default(ACTIVE)
  nextBillingAt DateTime
  cancelledAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  user          User        @relation(fields: [userId], references: [id])
  sponsorship   Sponsorship? @relation(fields: [sponsorshipId], references: [id])
  payment       Payment?    @relation(fields: [paymentId], references: [id])
}

model TaxReceipt {
  id         String   @id @default(cuid())
  userId     String
  donationId String   @unique
  year       Int
  amount     Decimal  @db.Decimal(12, 2)
  currency   String
  pdfUrl     String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  donation   Donation @relation(fields: [donationId], references: [id])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel
  title     String
  body      String
  data      Json?
  isRead    Boolean             @default(false)
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  user      User                @relation(fields: [userId], references: [id])
}

model Review {
  id          String    @id @default(cuid())
  userId      String
  orphanageId String
  rating      Int       // 1 à 5
  comment     String?   @db.Text
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])
  orphanage   Orphanage @relation(fields: [orphanageId], references: [id])

  @@unique([userId, orphanageId])
}

model Testimonial {
  id          String            @id @default(cuid())
  userId      String
  orphanageId String?
  content     String            @db.Text
  imageUrl    String?
  status      TestimonialStatus @default(PENDING)
  createdAt   DateTime          @default(now())

  user        User              @relation(fields: [userId], references: [id])
  orphanage   Orphanage?        @relation(fields: [orphanageId], references: [id])
}

model Event {
  id          String      @id @default(cuid())
  orphanageId String
  title       String
  description String      @db.Text
  location    String?
  imageUrl    String?
  status      EventStatus @default(UPCOMING)
  startsAt    DateTime
  endsAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  orphanage   Orphanage   @relation(fields: [orphanageId], references: [id])
  engagements Engagement[]
}

model Engagement {
  id          String   @id @default(cuid())
  userId      String
  eventId     String?
  type        String   // "VOLUNTEER" | "EVENT_PARTICIPATION" | "SOCIAL_SHARE"
  skills      String?  // pour les bénévoles
  availability String? // pour les bénévoles
  message     String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  event       Event?   @relation(fields: [eventId], references: [id])
}
